<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal WiX v3 manifest for the Stunda .msi installer.

  Compile from app/ after building the Windows Release. Invoke candle.exe with
  -arch x64, the path to this file, -out product.wixobj and a -dSourceDir
  pointing at build\windows\x64\runner\Release, then run light.exe on the
  product.wixobj to emit Stunda-windows-x64.msi. The exact command is in
  docs/RELEASE.md and the release.yml "Build .msi (WiX v3)" step.

  The UpgradeCode and MainExecutable Guid below are PERMANENT project-owned
  GUIDs. They must NEVER be changed — Windows Installer uses UpgradeCode to
  identify the product across versions (in-place upgrades via MajorUpgrade),
  and a different GUID would create a second Add/Remove Programs entry.
  The Product Id="*" auto-generates per build (correct for versioned releases).
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="Stunda"
           Language="1033"
           Version="2.0.0.0"
           Manufacturer="Kodsama"
           UpgradeCode="8A12A9FB-2887-443B-98B6-E939A2A04673">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="Stunda installer" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of Stunda is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Harvest the whole Release folder. SourceDir is passed via -d on candle. -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Stunda" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Stunda" />
      </Directory>
    </Directory>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="26829DD8-8888-4F20-84E4-4DEDE21CD08F">
        <File Id="StundaExe"
              Source="$(var.SourceDir)\stunda.exe"
              KeyPath="yes">
          <Shortcut Id="StartMenuShortcut"
                    Directory="ApplicationProgramsFolder"
                    Name="Stunda"
                    WorkingDirectory="INSTALLFOLDER"
                    Advertise="yes" />
        </File>
      </Component>
    </DirectoryRef>

    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <!--
        For a complete install, harvest the rest of the Release folder (DLLs and
        the data/ directory) with WiX `heat.exe`:
          heat.exe dir build\windows\x64\runner\Release -cg AppFiles -gg ^
            -srd -sfrag -dr INSTALLFOLDER -var var.SourceDir -out harvested.wxs
        then add harvested.wxs to the candle invocation. The MainExecutable
        component above guarantees a minimally valid .msi on its own.
      -->
    </ComponentGroup>

    <Feature Id="MainFeature" Title="Stunda" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentGroupRef Id="AppFiles" />
    </Feature>
  </Product>
</Wix>
